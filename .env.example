# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
ANTHROPIC_API_KEY=

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=outreach@yourdomain.com
# Domain used for per-user sending addresses (e.g. john@yourdomain.com)
# Defaults to the domain part of RESEND_FROM_EMAIL if not set
OUTREACH_EMAIL_DOMAIN=

# Business discovery
SERP_API_KEY=

# Email finding (Hunter.io — optional, free tier available)
HUNTER_API_KEY=

# Stripe billing (optional — app works without it, billing features disabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# App URL (used for Stripe redirects and email unsubscribe links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Legal — physical mailing address shown in email footers (required by CAN-SPAM)
COMPANY_ADDRESS=Your Company · 123 Main St · City, State ZIP

# Role email forwarding (support@, billing@, legal@, dmca@, security@)
ROLE_FORWARD_EMAIL=support@yourdomain.com
FORWARD_WEBHOOK_SECRET=

# Error monitoring (Sentry — optional but recommended for production)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Admin system — super-admin email (server-side only, never expose to client)
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Analytics (PostHog — session replay, heatmaps, funnels, A/B testing)
# Free up to 1M events/month. Get key at app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
